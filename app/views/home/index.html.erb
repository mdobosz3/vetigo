<style>
  .hero-section { text-align: center; padding: 40px 20px; }
  .hero-section h1 { font-size: 2.5rem; font-weight: 800; color: #111827; margin-bottom: 10px; }
  .hero-section p { font-size: 1.1rem; color: #4b5563; max-width: 600px; margin: 0 auto; }

  .map-wrapper { max-width: 1200px; margin: 0 auto 50px; padding: 0 15px; }

  /* Gwarantujemy wysokość mapy */
  #map { 
    height: 600px !important; 
    width: 100% !important; 
    border-radius: 20px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    border: 1px solid #e5e7eb;
    background: #f3f4f6;
    display: block !important;
  }

  /* Styl dla Twojej pozycji */
  .user-pos { background: #3b82f6; border: 2px solid white; border-radius: 50%; box-shadow: 0 0 10px rgba(59,130,246,0.6); }
</style>

<div class="hero-section">
  <h1>Znajdź najlepszą klinikę <b>dla swojego pupila</b></h1>
  <p>Twoje zwierzę zasługuje na najlepszą opiekę. Wybierz placówkę z mapy poniżej.</p>
</div>

<div class="map-wrapper">
  <div id="map" data-clinics="<%= @clinics.to_json(only: [:name, :latitude, :longitude, :address, :city]) %>"></div>
</div>

<script>
  function initMap() {
    const mapElement = document.getElementById('map');
    if (!mapElement || mapElement._leaflet_id) return;

    // Pobranie danych klinik
    let clinics = [];
    try {
      clinics = JSON.parse(mapElement.getAttribute('data-clinics')) || [];
    } catch (e) {
      console.error("Błąd danych klinik:", e);
    }

    // Inicjalizacja mapy (na start Warszawa)
    const map = L.map('map').setView([52.2297, 21.0122], 12);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap'
    }).addTo(map);

    const bounds = [];

    // Dodawanie klinik
    clinics.forEach(clinic => {
      if (clinic.latitude && clinic.longitude) {
        const loc = [clinic.latitude, clinic.longitude];
        L.marker(loc).addTo(map).bindPopup(`<b>${clinic.name}</b><br>${clinic.address}`);
        bounds.push(loc);
      }
    });

    // Próba geolokalizacji użytkownika
    map.locate({setView: false, maxZoom: 14});

    map.on('locationfound', function(e) {
      const userMarker = L.divIcon({ className: 'user-pos', iconSize: [12, 12] });
      L.marker(e.latlng, {icon: userMarker}).addTo(map).bindPopup("Tu jesteś").openPopup();
      
      bounds.push([e.latitude, e.longitude]);
      map.fitBounds(bounds, {padding: [50, 50]});
    });

    map.on('locationerror', function() {
      if (bounds.length > 0) map.fitBounds(bounds, {padding: [50, 50]});
    });

    // Ostateczne wymuszenie rozmiaru
    setTimeout(() => { map.invalidateSize(); }, 400);
  }

  // Obsługa Turbo i ładowania
  document.addEventListener("turbo:load", initMap);
  if (document.readyState === "complete") initMap();
</script>
