<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Vetigo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 text-gray-900">
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-20 items-center">
          
          <div class="flex items-center gap-6">
            <a href="/" class="text-3xl font-extrabold text-indigo-600 no-underline tracking-tight">Vetigo</a>
            
            <% if user_signed_in? && !current_user.admin? %>
              <div class="hidden md:flex space-x-3">
                <%= link_to "Zwierzaki", pets_path, class: "bg-indigo-50 border border-indigo-200 text-indigo-700 hover:bg-indigo-100 hover:text-indigo-800 hover:border-indigo-300 px-5 py-2 rounded-full shadow-sm text-sm font-semibold transition-all" %>
                <%= link_to "Wizyty", appointments_path, class: "bg-indigo-50 border border-indigo-200 text-indigo-700 hover:bg-indigo-100 hover:text-indigo-800 hover:border-indigo-300 px-5 py-2 rounded-full shadow-sm text-sm font-semibold transition-all" %>
              </div>
            <% elsif user_signed_in? && current_user.admin? %>
              <div class="hidden md:flex space-x-3">
                <%= link_to "Panel Administratora", "/avo", class: "bg-purple-50 border border-purple-200 text-purple-700 hover:bg-purple-100 hover:border-purple-300 px-5 py-2 rounded-full shadow-sm text-sm font-semibold transition-all" %>
              </div>
            <% end %>
          </div>

          <div class="flex items-center space-x-3">
            <% if user_signed_in? %>
              <div class="relative group">
                <button class="flex items-center bg-gray-100 border border-gray-200 hover:bg-gray-200 text-gray-800 px-5 py-2 rounded-full text-sm font-semibold shadow-sm transition-all focus:outline-none">
                  <%= current_user.email %>
                  <svg class="ml-2 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>

                <div class="hidden group-hover:block absolute right-0 mt-2 w-48 bg-white border border-gray-100 rounded-2xl shadow-xl py-2 z-50 overflow-hidden">
                  <%= link_to "Mój profil", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-700 transition" %>
                  <hr class="my-1 border-gray-100">
                  <%= link_to "Wyloguj się", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition" %>
                </div>
              </div>
            <% else %>
              <%= link_to "Zaloguj się", new_user_session_path, class: "bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 px-5 py-2 rounded-full shadow-sm text-sm font-semibold transition-all" %>
              <%= link_to "Zarejestruj się", new_user_registration_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-full shadow-sm text-sm font-semibold transition-all" %>
            <% end %>
          </div>

        </div>
      </div>
    </nav>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
      <% if notice.present? %>
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-2xl relative mb-4 shadow-sm" role="alert">
          <span class="block sm:inline font-medium"><%= notice %></span>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-2xl relative mb-4 shadow-sm" role="alert">
          <span class="block sm:inline font-medium"><%= alert %></span>
        </div>
      <% end %>
    </div>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
