<style>
  /* Używamy tych samych stylów co powyżej */
  body { background-color: #f3f4f6; font-family: system-ui, -apple-system, sans-serif; }
  .login-container { max-width: 450px; margin: 5vh auto; background: white; padding: 2.5rem; border-radius: 12px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
  .login-container h2 { text-align: center; color: #111827; margin-bottom: 2rem; font-weight: 700; }
  .form-group { margin-bottom: 1.25rem; }
  .form-group label { display: block; margin-bottom: 0.5rem; color: #374151; font-weight: 600; font-size: 0.875rem; }
  .form-group input[type="email"], .form-group input[type="password"] { width: 100%; padding: 0.75rem; border: 1px solid #d1d5db; border-radius: 6px; box-sizing: border-box; font-size: 1rem; }
  .btn-primary { width: 100%; background-color: #3b82f6; color: white; padding: 0.75rem; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 1rem; }
  .btn-danger { background-color: transparent; color: #ef4444; border: 1px solid #ef4444; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; font-size: 0.875rem; transition: all 0.2s; }
  .btn-danger:hover { background-color: #ef4444; color: white; }
  .section-divider { border-top: 1px solid #e5e7eb; margin: 2rem 0; padding-top: 1rem; }
</style>

<div class="login-container">
  <h2>Edytuj swój profil</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-group">
      <%= f.label :email, "Adres Email" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
    </div>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <div style="font-size: 0.875rem; color: #6b7280; margin-bottom: 1rem;">
        Oczekiwanie na potwierdzenie dla: <%= resource.unconfirmed_email %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :password, "Nowe hasło" %> 
      <i style="font-size: 0.75rem; color: #6b7280;">(zostaw puste, jeśli nie chcesz zmieniać)</i>
      <%= f.password_field :password, autocomplete: "new-password" %>
    </div>

    <div class="form-group">
      <%= f.label :password_confirmation, "Potwierdź nowe hasło" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
    </div>

    <div class="form-group">
      <%= f.label :current_password, "Aktualne hasło" %> 
      <i style="font-size: 0.75rem; color: #6b7280;">(potrzebne do zatwierdzenia zmian)</i>
      <%= f.password_field :current_password, autocomplete: "current-password" %>
    </div>

    <div class="actions">
      <%= f.submit "Zapisz zmiany", class: "btn-primary" %>
    </div>
  <% end %>

  <div class="section-divider">
    <h3 style="font-size: 1rem; color: #111827; margin-bottom: 1rem;">Strefa bezpieczeństwa</h3>
    <p style="font-size: 0.875rem; color: #6b7280; margin-bottom: 1rem;">Chcesz usunąć swoje konto? Ta operacja jest nieodwracalna.</p>
    <%= button_to "Usuń moje konto", registration_path(resource_name), data: { confirm: "Jesteś pewien?", turbo_confirm: "Jesteś pewien?" }, method: :delete, class: "btn-danger" %>
  </div>

  <div class="login-links">
    <%= link_to "← Powrót", :back %>
  </div>
</div>
