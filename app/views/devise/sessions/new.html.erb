<div class="max-w-md mx-auto mt-12 bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
  <div class="text-center mb-8">
    <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">Witaj ponownie</h2>
    <p class="text-gray-500 mt-2">Zaloguj się do swojego konta Vetigo</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
    
    <div>
      <%= f.label :email, "Adres e-mail", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-2xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 transition-all px-4 py-3" %>
    </div>

    <div>
      <%= f.label :password, "Hasło", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-2xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 transition-all px-4 py-3" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center">
        <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600 shadow-sm focus:border-indigo-300 focus:ring focus:ring-offset-0 focus:ring-indigo-200 focus:ring-opacity-50 h-4 w-4" %>
        <%= f.label :remember_me, "Zapamiętaj mnie", class: "ml-2 block text-sm text-gray-700" %>
      </div>
    <% end %>

    <div class="pt-2">
      <%= f.submit "Zaloguj się", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-full shadow-sm text-sm font-semibold transition-all cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-8 pt-6 border-t border-gray-100 text-center space-y-2">
    <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
      <%= link_to "Zapomniałeś hasła?", new_password_path(resource_name), class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium transition-all block" %><br />
    <% end %>
    
    <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
      <span class="text-sm text-gray-500">Nie masz jeszcze konta?</span>
      <%= link_to "Zarejestruj się", new_registration_path(resource_name), class: "text-sm text-indigo-600 hover:text-indigo-800 font-bold transition-all" %><br />
    <% end %>
  </div>
</div>
