<div class="max-w-2xl mx-auto py-8">
  <h1 class="text-3xl font-extrabold text-gray-900 mb-6">Edit Pet</h1>

  <%= form_with(model: @pet, class: "bg-white p-6 rounded-3xl shadow-sm border border-gray-100") do |form| %>
    <% if @pet.errors.any? %>
      <div class="bg-red-50 text-red-800 p-4 rounded-xl mb-6">
        <ul>
          <% @pet.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="mb-4">
      <%= form.label :species, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :species, class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>
    
    <div class="mb-4">
      <%= form.label :breed, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :breed, class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="mb-6">
      <%= form.label :age, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.number_field :age, class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <div class="flex gap-4">
      <%= form.submit "Save changes", class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-full shadow-sm text-sm font-semibold transition-all cursor-pointer" %>
      <%= link_to "Cancel", pets_path, class: "bg-gray-100 hover:bg-gray-200 text-gray-800 px-6 py-2 rounded-full shadow-sm text-sm font-semibold transition-all" %>
    </div>
  <% end %>
</div>
