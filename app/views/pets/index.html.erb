<div class="flex justify-between items-center mb-8">
  <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Twoje zwierzaki</h1>
  <%= link_to "Dodaj zwierzaka", new_pet_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-full shadow-sm text-sm font-semibold transition-all" %>
</div>

<% if @pets.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @pets.each do |pet| %>
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-all">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-indigo-50 text-indigo-600 rounded-full h-14 w-14 flex items-center justify-center font-bold text-2xl">
            <%= pet.name.first.upcase %>
          </div>
          <div>
            <h2 class="text-xl font-bold text-gray-900">
              <%= pet.name %> <span class="text-sm font-medium text-indigo-500">(<%= pet.species %>)</span>
            </h2>
            <p class="text-sm text-gray-500"><%= pet.breed.presence || "Mieszaniec" %></p>
          </div>
        </div>
        
        <div class="text-sm text-gray-700 bg-gray-50 rounded-2xl p-3">
          <p><span class="font-semibold text-gray-500">Wiek:</span> <%= pet.age %> lat</p>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-12 text-center mt-10">
    <h3 class="text-xl font-bold text-gray-900 mb-2">Nie masz jeszcze żadnych zwierzaków</h3>
    <p class="text-gray-500 mb-8">Dodaj swojego pierwszego podopiecznego, aby móc umawiać go na wizyty w klinikach Vetigo.</p>
    <%= link_to "Dodaj pierwszego zwierzaka", new_pet_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-full shadow-sm text-base font-semibold transition-all" %>
  </div>
<% end %>
