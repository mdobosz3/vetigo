<div class="max-w-2xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Dodaj zwierzaka</h1>
    <%= link_to "Wróć do listy", pets_path, class: "text-indigo-600 hover:text-indigo-800 font-semibold text-sm transition-all" %>
  </div>

  <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
    <%= form_with(model: @pet, local: true, class: "space-y-6") do |f| %>
      
      <% if @pet.errors.any? %>
        <div class="bg-red-50 text-red-800 p-4 rounded-2xl mb-6 border border-red-200 shadow-sm">
          <h2 class="font-bold mb-2">Popraw poniższe błędy:</h2>
          <ul class="list-disc pl-5 text-sm">
            <% @pet.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Imię zwierzaka", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.text_field :name, class: "w-full rounded-2xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 transition-all px-4 py-2" %>
      </div>

      <div>
        <%= f.label :species, "Gatunek", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.select :species, ["Dog", "Cat", "Rabbit", "Hamster", "Parrot", "Other"], { prompt: "Wybierz gatunek" }, class: "w-full rounded-2xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 transition-all px-4 py-2" %>
      </div>

      <div>
        <%= f.label :breed, "Rasa (opcjonalnie)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.text_field :breed, class: "w-full rounded-2xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 transition-all px-4 py-2" %>
      </div>

      <div>
        <%= f.label :age, "Wiek (w latach)", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.number_field :age, class: "w-full rounded-2xl border-gray-300 shadow-sm focus:border-indigo-500 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 transition-all px-4 py-2" %>
      </div>

      <div class="pt-6 flex items-center justify-end gap-4 border-t border-gray-100 mt-8">
        <%= link_to "Anuluj", pets_path, class: "text-gray-500 hover:text-gray-800 font-semibold text-sm px-4 py-2 transition-all" %>
        <%= f.submit "Zapisz zwierzaka", class: "bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-3 rounded-full shadow-sm text-sm font-semibold transition-all cursor-pointer" %>
      </div>
      
    <% end %>
  </div>
</div>
